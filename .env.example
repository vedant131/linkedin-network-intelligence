# Copy this file to .env and fill in values
# AI Mode: "openai" uses GPT-4o-mini (best), "offline" uses local rules (no key needed)
AI_MODE=offline

# Required only when AI_MODE=openai
OPENAI_API_KEY=sk-...

# Enable company prestige tier scoring (FAANG boost)
COMPANY_TIER_SCORING=true

# ── WhatsApp Bot (Twilio) ──────────────────────────────────────────────────────
# Get these from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sandbox number (for testing) — leave as-is unless you have a paid number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Your deployed app URL (used in bot "not registered" message)
# Local: http://localhost:3000
# Production: https://vedant131.github.io/linkedin-network-intelligence
WEBSITE_URL=http://localhost:3000
